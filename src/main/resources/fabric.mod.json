{
	"schemaVersion": 1,
	"id": "terracotta-client",
	"version": "${version}",
	"name": "Terracotta Client",
	"description": "Enables easy development using Terracotta by allowing external applications (such as VSCode) to interface directly with DiamondFire.\n\nReport bugs on the Discord or GitHub.",
	"authors": [
		"Owlfroggy"
	],
	"contact": {
		"homepage": "https://owlfroggy.github.io/terracotta-docs/",
		"sources": "https://github.com/Owlfroggy/terracotta-client-mod"
	},
	"license": "BSD-3-Clause",
	"icon": "assets/terracotta-client/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
          "owlfroggy.terracottaclient.TCClient"
		],
        "modmenu": [
          "owlfroggy.terracottaclient.ui.ModMenuIntegration"
        ]
	},
	"mixins": [
		"terracotta-client.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	},
    "custom": {
        "modmenu": {
            "links": {
               "modmenu.discord": "https://discord.gg/at9uBFXPxy"
            }
        }
    }
}